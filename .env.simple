# Simple Configuration - No API Keys Required

# Application
APP_NAME=AI Sustainability Agent
DEBUG=True
API_HOST=127.0.0.1
API_PORT=8000

# Simple Mode (no API keys)
USE_SIMPLE_MODE=true

# Database (SQLite - simple file-based database)
